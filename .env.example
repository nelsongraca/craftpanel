# CraftPanel — environment variables
# Copy to .env and fill in all required values before running docker compose up.

# Public hostname (must resolve to this server's IP — used for HTTPS and routing)
DOMAIN=panel.example.com

# Let's Encrypt registration email
ACME_EMAIL=you@example.com

# PostgreSQL password — use a strong random value
DB_PASSWORD=changeme

# JWT signing secret — minimum 32 characters, random
JWT_SECRET=replace-with-a-random-32-character-string

# Shared secret for node registration — minimum 16 characters, random
NODE_BOOTSTRAP_TOKEN=replace-with-a-secret-token

# Initial Super Admin credentials — only applied when the users table is empty.
# Safe to leave set after first boot; ignored once any user exists.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

# Image version to deploy (defaults to latest)
# IMAGE_VERSION=1.0.0

# Host path for Minecraft server data.
# Must be an absolute path that exists on the host before starting the agent.
# Minecraft containers are bind-mounted here; use a bind-mount, not a named volume.
HOST_DATA_PATH=/opt/craftpanel/data
